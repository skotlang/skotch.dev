---
// Roadmap component: reads milestones.json (generated by the pre-build
// script) and renders a visual milestone timeline.
import milestones from '../data/milestones.json';

const items = milestones.milestones ?? [];
---

<div class="not-content roadmap-section">
  <h2 class="roadmap-heading">Roadmap</h2>

  <div class="roadmap-timeline">
    {items.map((m: any) => {
      const done = m.status === 'completed';
      const featureCount = m.features?.length ?? 0;
      return (
        <div class={`roadmap-card ${done ? 'done' : 'planned'}`}>
          <div class="roadmap-card-header">
            <span class="roadmap-check" aria-hidden="true">
              {done ? '✓' : '○'}
            </span>
            <div class="roadmap-version-block">
              <span class="roadmap-version">v{m.version}</span>
              <span class="roadmap-title">{m.title}</span>
            </div>
            {done && <span class="roadmap-badge">Shipped</span>}
          </div>
          <p class="roadmap-desc">{m.description}</p>
          {featureCount > 0 && !done && (() => {
            const doneCount = m.features.filter((f: any) => f.completed).length;
            const summaryText = doneCount > 0
              ? `${doneCount}/${featureCount} feature${featureCount === 1 ? '' : 's'} complete`
              : `${featureCount} feature${featureCount === 1 ? '' : 's'}`;
            return (
              <details class="roadmap-features">
                <summary>{summaryText}</summary>
                <ul>
                  {m.features.map((f: any) => (
                    <li class={f.completed ? 'feature-done' : 'feature-pending'}>
                      <span class="feature-check" aria-hidden="true">{f.completed ? '✓' : '○'}</span>
                      {f.name}
                    </li>
                  ))}
                </ul>
              </details>
            );
          })()}
        </div>
      );
    })}
  </div>
</div>

<style>
  .roadmap-section {
    margin-top: 2.5rem;
    margin-bottom: 2rem;
  }

  .roadmap-heading {
    font-size: 1.75rem;
    font-weight: 700;
    text-align: center;
    color: var(--sl-color-white);
    margin: 0 0 0.25rem;
  }

  .roadmap-subtext {
    text-align: center;
    font-size: 0.9375rem;
    color: var(--sl-color-gray-2);
    margin: 0 0 1.75rem;
  }

  :root[data-theme='light'] .roadmap-subtext {
    color: var(--sl-color-gray-3);
  }

  .roadmap-timeline {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 640px;
    margin: 0 auto;
  }

  /* ── Card ── */

  .roadmap-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--sl-color-gray-6);
    transition: border-color 0.15s ease;
  }

  .roadmap-card.done {
    border-color: hsl(130, 40%, 30%);
    background: hsla(130, 30%, 14%, 0.5);
  }

  :root[data-theme='light'] .roadmap-card.done {
    border-color: hsl(130, 45%, 55%);
    background: hsla(130, 50%, 92%, 0.6);
  }

  :root[data-theme='light'] .roadmap-card {
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }

  .roadmap-card-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  /* ── Check icon ── */

  .roadmap-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    flex-shrink: 0;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .done .roadmap-check {
    background: hsl(130, 50%, 28%);
    color: hsl(130, 80%, 70%);
  }

  :root[data-theme='light'] .done .roadmap-check {
    background: hsl(130, 55%, 42%);
    color: #fff;
  }

  .planned .roadmap-check {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
    font-size: 0.75rem;
  }

  /* ── Version + title ── */

  .roadmap-version-block {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .roadmap-version {
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sl-color-white);
    white-space: nowrap;
  }

  .roadmap-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--sl-color-gray-1);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :root[data-theme='light'] .roadmap-title {
    color: var(--sl-color-gray-2);
  }

  /* ── Badge ── */

  .roadmap-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border-radius: 2rem;
    background: hsl(130, 50%, 28%);
    color: hsl(130, 80%, 70%);
    white-space: nowrap;
  }

  :root[data-theme='light'] .roadmap-badge {
    background: hsl(130, 55%, 42%);
    color: #fff;
  }

  /* ── Description ── */

  .roadmap-desc {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    margin: 0.5rem 0 0;
    padding-left: 2.375rem;
  }

  :root[data-theme='light'] .roadmap-desc {
    color: var(--sl-color-gray-3);
  }

  /* ── Feature details ── */

  .roadmap-features {
    margin: 0.5rem 0 0;
    padding-left: 2.375rem;
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
  }

  :root[data-theme='light'] .roadmap-features {
    color: var(--sl-color-gray-3);
  }

  .roadmap-features summary {
    cursor: pointer;
    font-weight: 500;
    color: var(--sl-color-gray-1);
  }

  :root[data-theme='light'] .roadmap-features summary {
    color: var(--sl-color-gray-2);
  }

  .roadmap-features ul {
    margin: 0.375rem 0 0;
    padding-left: 0.25rem;
    list-style: none;
  }

  .roadmap-features li {
    margin: 0.25rem 0;
    line-height: 1.4;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .feature-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    flex-shrink: 0;
    font-size: 0.625rem;
    font-weight: 700;
  }

  .feature-done .feature-check {
    background: hsl(130, 50%, 28%);
    color: hsl(130, 80%, 70%);
  }

  :root[data-theme='light'] .feature-done .feature-check {
    background: hsl(130, 55%, 42%);
    color: #fff;
  }

  .feature-pending .feature-check {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
    font-size: 0.5rem;
  }

  .feature-done {
    color: var(--sl-color-gray-1);
  }

  :root[data-theme='light'] .feature-done {
    color: var(--sl-color-gray-2);
  }

  /* ── LOC estimate ── */

  .roadmap-loc {
    display: inline-block;
    margin-top: 0.375rem;
    margin-left: 2.375rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
  }

  :root[data-theme='light'] .roadmap-loc {
    color: var(--sl-color-gray-4);
  }
</style>
