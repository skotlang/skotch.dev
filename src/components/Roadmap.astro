---
// Roadmap component: reads milestones.json (generated by the pre-build
// script) and renders a visual milestone timeline.
import milestones from '../data/milestones.json';

const items = milestones.milestones ?? [];
const cardColors = ['green', 'blue', 'purple', 'amber', 'teal', 'red', 'cyan', 'rose', 'indigo'];
let colorIdx = 0;
---

<div class="not-content roadmap-section">
  <h2 class="roadmap-heading">Roadmap</h2>

  <div class="roadmap-timeline">
    {items.map((m: any) => {
      const done = m.status === 'completed';
      const featureCount = m.features?.length ?? 0;
      const color = done ? 'green' : cardColors[colorIdx++ % cardColors.length];
      return (
        <div class={`roadmap-card ${done ? 'done' : 'planned'}`} data-color={color}>
          <div class="roadmap-card-header">
            <span class="roadmap-check" aria-hidden="true">
              {done ? '✓' : '○'}
            </span>
            <div class="roadmap-version-block">
              <span class="roadmap-version">v{m.version}</span>
              <span class="roadmap-title">{m.title}</span>
            </div>
            {done && <span class="roadmap-badge">Shipped</span>}
          </div>
          <p class="roadmap-desc">{m.description}</p>
          {featureCount > 0 && !done && (() => {
            const doneCount = m.features.filter((f: any) => f.completed).length;
            const summaryText = doneCount > 0
              ? `${doneCount}/${featureCount} feature${featureCount === 1 ? '' : 's'} complete`
              : `${featureCount} feature${featureCount === 1 ? '' : 's'}`;
            return (
              <details class="roadmap-features">
                <summary>{summaryText}</summary>
                <ul>
                  {m.features.map((f: any) => {
                    const desc = f.description?.trim();
                    const ac: string[] = f.acceptance_criteria ?? [];
                    const hasTooltip = desc || ac.length > 0;
                    return (
                      <li class={f.completed ? 'feature-done' : 'feature-pending'}>
                        <span class="feature-check" aria-hidden="true">{f.completed ? '✓' : '○'}</span>
                        <span class={`feature-name${hasTooltip ? ' has-tooltip' : ''}`}>
                          {f.name}
                          {hasTooltip && (
                            <div class="feature-tooltip">
                              {desc && <p class="tooltip-desc">{desc}</p>}
                              {ac.length > 0 && (
                                <>
                                  <p class="tooltip-heading">Acceptance criteria</p>
                                  <ul class="tooltip-criteria">
                                    {ac.map((c: string) => <li>{c}</li>)}
                                  </ul>
                                </>
                              )}
                            </div>
                          )}
                        </span>
                      </li>
                    );
                  })}
                </ul>
              </details>
            );
          })()}
        </div>
      );
    })}
  </div>
</div>

<style>
  .roadmap-section {
    margin-top: 2.5rem;
    margin-bottom: 2rem;
  }

  .roadmap-heading {
    font-size: 1.75rem;
    font-weight: 700;
    text-align: center;
    color: var(--sl-color-white);
    margin: 0 0 0.25rem;
  }

  .roadmap-subtext {
    text-align: center;
    font-size: 0.9375rem;
    color: var(--sl-color-gray-2);
    margin: 0 0 1.75rem;
  }

  :root[data-theme='light'] .roadmap-subtext {
    color: var(--sl-color-gray-3);
  }

  .roadmap-timeline {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 640px;
    margin: 0 auto;
  }

  /* ── Card ── */

  .roadmap-card {
    border: 1px solid var(--card-border, var(--sl-color-gray-5));
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--card-bg, var(--sl-color-gray-6));
    transition: border-color 0.15s ease;
  }

  :root[data-theme='light'] .roadmap-card {
    background: var(--card-bg-light, var(--sl-color-gray-7, var(--sl-color-gray-6)));
    border-color: var(--card-border-light, var(--sl-color-gray-5));
  }

  /* ── Per-card colors (dark) ── */
  .roadmap-card[data-color="green"]  { --card-bg: hsla(130, 30%, 14%, 0.5);  --card-border: hsl(130, 40%, 30%); }
  .roadmap-card[data-color="blue"]   { --card-bg: hsla(217, 35%, 16%, 0.5);  --card-border: hsl(217, 40%, 35%); }
  .roadmap-card[data-color="purple"] { --card-bg: hsla(270, 30%, 18%, 0.5);  --card-border: hsl(270, 35%, 38%); }
  .roadmap-card[data-color="amber"]  { --card-bg: hsla(38, 35%, 14%, 0.5);   --card-border: hsl(38, 45%, 32%); }
  .roadmap-card[data-color="teal"]   { --card-bg: hsla(174, 30%, 14%, 0.5);  --card-border: hsl(174, 40%, 30%); }
  .roadmap-card[data-color="red"]    { --card-bg: hsla(0, 30%, 16%, 0.5);    --card-border: hsl(0, 35%, 35%); }
  .roadmap-card[data-color="cyan"]   { --card-bg: hsla(195, 35%, 15%, 0.5);  --card-border: hsl(195, 40%, 32%); }
  .roadmap-card[data-color="rose"]   { --card-bg: hsla(330, 30%, 16%, 0.5);  --card-border: hsl(330, 35%, 35%); }
  .roadmap-card[data-color="indigo"] { --card-bg: hsla(240, 30%, 17%, 0.5);  --card-border: hsl(240, 35%, 36%); }

  /* ── Per-card colors (light) ── */
  :root[data-theme='light'] .roadmap-card[data-color="green"]  { --card-bg-light: hsla(130, 50%, 92%, 0.6);  --card-border-light: hsl(130, 45%, 55%); }
  :root[data-theme='light'] .roadmap-card[data-color="blue"]   { --card-bg-light: hsla(217, 55%, 94%, 0.6);  --card-border-light: hsl(217, 50%, 58%); }
  :root[data-theme='light'] .roadmap-card[data-color="purple"] { --card-bg-light: hsla(270, 50%, 94%, 0.6);  --card-border-light: hsl(270, 45%, 60%); }
  :root[data-theme='light'] .roadmap-card[data-color="amber"]  { --card-bg-light: hsla(38, 60%, 92%, 0.6);   --card-border-light: hsl(38, 55%, 52%); }
  :root[data-theme='light'] .roadmap-card[data-color="teal"]   { --card-bg-light: hsla(174, 50%, 92%, 0.6);  --card-border-light: hsl(174, 45%, 45%); }
  :root[data-theme='light'] .roadmap-card[data-color="red"]    { --card-bg-light: hsla(0, 50%, 94%, 0.6);    --card-border-light: hsl(0, 50%, 60%); }
  :root[data-theme='light'] .roadmap-card[data-color="cyan"]   { --card-bg-light: hsla(195, 55%, 93%, 0.6);  --card-border-light: hsl(195, 50%, 48%); }
  :root[data-theme='light'] .roadmap-card[data-color="rose"]   { --card-bg-light: hsla(330, 50%, 94%, 0.6);  --card-border-light: hsl(330, 45%, 58%); }
  :root[data-theme='light'] .roadmap-card[data-color="indigo"] { --card-bg-light: hsla(240, 50%, 95%, 0.6);  --card-border-light: hsl(240, 45%, 62%); }

  .roadmap-card-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  /* ── Check icon ── */

  .roadmap-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    flex-shrink: 0;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .done .roadmap-check {
    background: hsl(130, 50%, 28%);
    color: hsl(130, 80%, 70%);
  }

  :root[data-theme='light'] .done .roadmap-check {
    background: hsl(130, 55%, 42%);
    color: #fff;
  }

  .planned .roadmap-check {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
    font-size: 0.75rem;
  }

  /* ── Version + title ── */

  .roadmap-version-block {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .roadmap-version {
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sl-color-white);
    white-space: nowrap;
  }

  .roadmap-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--sl-color-gray-1);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :root[data-theme='light'] .roadmap-title {
    color: var(--sl-color-gray-2);
  }

  /* ── Badge ── */

  .roadmap-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border-radius: 2rem;
    background: hsl(130, 50%, 28%);
    color: hsl(130, 80%, 70%);
    white-space: nowrap;
  }

  :root[data-theme='light'] .roadmap-badge {
    background: hsl(130, 55%, 42%);
    color: #fff;
  }

  /* ── Description ── */

  .roadmap-desc {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    margin: 0.5rem 0 0;
    padding-left: 2.375rem;
  }

  :root[data-theme='light'] .roadmap-desc {
    color: var(--sl-color-gray-3);
  }

  /* ── Feature details ── */

  .roadmap-features {
    margin: 0.5rem 0 0;
    padding-left: 2.375rem;
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
  }

  :root[data-theme='light'] .roadmap-features {
    color: var(--sl-color-gray-3);
  }

  .roadmap-features summary {
    cursor: pointer;
    font-weight: 500;
    color: var(--sl-color-gray-1);
  }

  :root[data-theme='light'] .roadmap-features summary {
    color: var(--sl-color-gray-2);
  }

  .roadmap-features ul {
    margin: 0.375rem 0 0;
    padding-left: 0.25rem;
    list-style: none;
  }

  .roadmap-features li {
    margin: 0.25rem 0;
    line-height: 1.4;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .feature-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    flex-shrink: 0;
    font-size: 0.625rem;
    font-weight: 700;
  }

  .feature-done .feature-check {
    background: hsl(130, 50%, 28%);
    color: hsl(130, 80%, 70%);
  }

  :root[data-theme='light'] .feature-done .feature-check {
    background: hsl(130, 55%, 42%);
    color: #fff;
  }

  .feature-pending .feature-check {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
    font-size: 0.5rem;
  }

  .feature-done {
    color: var(--sl-color-gray-1);
  }

  :root[data-theme='light'] .feature-done {
    color: var(--sl-color-gray-2);
  }

  /* ── Custom tooltip ── */

  .feature-name.has-tooltip {
    position: relative;
    cursor: default;
    text-decoration: underline dotted var(--sl-color-gray-4);
    text-underline-offset: 2px;
  }

  .feature-tooltip {
    display: none;
    position: absolute;
    left: calc(100% + 0.75rem);
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    width: 340px;
    padding: 0.875rem 1rem;
    border-radius: 0.75rem;
    border: 3px solid var(--sl-color-accent);
    background: var(--sl-color-black);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.05);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--sl-color-gray-1);
    pointer-events: none;
  }

  :root[data-theme='light'] .feature-tooltip {
    background: #ffffff;
    border-color: var(--sl-color-accent);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.06);
    color: var(--sl-color-gray-2);
  }

  /* Arrow pointing left */
  .feature-tooltip::after {
    content: '';
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    border: 8px solid transparent;
    border-right-color: var(--sl-color-accent);
  }

  /* Inner arrow (matches background) */
  .feature-tooltip::before {
    content: '';
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-right-color: var(--sl-color-black);
    z-index: 1;
    margin-right: -3px;
  }

  :root[data-theme='light'] .feature-tooltip::before {
    border-right-color: #ffffff;
  }

  .feature-name.has-tooltip:hover .feature-tooltip {
    display: block;
  }

  .tooltip-desc {
    margin: 0 0 0.375rem;
    color: var(--sl-color-gray-2);
  }

  :root[data-theme='light'] .tooltip-desc {
    color: var(--sl-color-gray-3);
  }

  .tooltip-heading {
    margin: 0 0 0.25rem;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--sl-color-gray-3);
  }

  :root[data-theme='light'] .tooltip-heading {
    color: var(--sl-color-gray-4);
  }

  .tooltip-criteria {
    margin: 0;
    padding-left: 1rem;
    list-style: disc;
  }

  .tooltip-criteria li {
    display: list-item;
    margin: 0.125rem 0;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
  }

  :root[data-theme='light'] .tooltip-criteria li {
    color: var(--sl-color-gray-3);
  }

  /* ── LOC estimate ── */

  .roadmap-loc {
    display: inline-block;
    margin-top: 0.375rem;
    margin-left: 2.375rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    font-family: var(--sl-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
  }

  :root[data-theme='light'] .roadmap-loc {
    color: var(--sl-color-gray-4);
  }
</style>
